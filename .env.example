DATABASE_URL=postgresql+asyncpg://wb_user:wb_pass_2024@localhost:5432/wrong_book
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
AES_KEY=change-me-32bytes-secret-key-ok!
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro
# MiniMax Token Plan Key。仅保存在本地 .env，不要提交真实值。
MINIMAX_API_KEY=
# 国内 Key 使用 https://api.minimaxi.com；海外 Key 使用 https://api.minimax.io。
MINIMAX_API_HOST=https://api.minimaxi.com
# 单次图片理解请求超时秒数。
MINIMAX_VISION_TIMEOUT_SECONDS=60
# 仅针对超时、网络错误、HTTP 429 和 5xx 的最大重试次数。
MINIMAX_VISION_MAX_RETRIES=2
# 两次重试之间的等待秒数。
MINIMAX_VISION_RETRY_DELAY_SECONDS=1
# 自动确认阈值；低于该值的题目进入人工确认。
MINIMAX_CONFIDENCE_THRESHOLD=0.85
# 错题区域二次定位的最低置信度；低于该值时展示完整原图并进入人工复核。
MINIMAX_LOCALIZATION_CONFIDENCE_THRESHOLD=0.85
# 预处理后图片最长边像素数。
MINIMAX_IMAGE_MAX_EDGE=2048
# 预处理 JPEG 质量（1-100）。
MINIMAX_IMAGE_JPEG_QUALITY=90
# 模型标签英文别名和题型默认中文标签配置文件。
TAG_ALIAS_CONFIG_PATH=./config/tag-aliases.json
# 调试业务数据清理命令要求精确匹配的确认口令。
DEBUG_DATA_RESET_CONFIRMATION_PHRASE=CLEAR_DEBUG_BUSINESS_DATA
# 错题详情图片允许解码的最大像素总数，超过时拒绝处理以限制内存占用。
QUESTION_IMAGE_MAX_PIXELS=40000000
# 软删除错题和无引用图片在物理清理前的保留天数。
QUESTION_SOFT_DELETE_RETENTION_DAYS=30
# 周期清理任务的执行间隔秒数；86400 表示每天一次。
QUESTION_CLEANUP_INTERVAL_SECONDS=86400
# 单次清理查询最多锁定和处理的记录数。
QUESTION_CLEANUP_BATCH_SIZE=100
UPLOAD_DIR=./uploads
PDF_DIR=./pdfs
WECHAT_APP_ID=
WECHAT_APP_SECRET=
DEV_MODE=true
